pipeline {
    agent any
    


    environment {
        APP_NAME        = "bankpay-service"
        DOCKERHUB_USER  = "riteshsingh90"
        IMAGE_NAME      = "${DOCKERHUB_USER}/${APP_NAME}"
        IMAGE_TAG       = "${BUILD_NUMBER}"
        SONAR_URL       = "http://sonarqube.bankpay.local:30001"
        HELM_CHART      = "helm/bankpay"
        GIT_REPO        = "https://github.com/Ritesh1914/bankpay-devops.git"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.GIT_COMMIT_MSG = sh(
                        script: 'git log -1 --pretty=%B',
                        returnStdout: true
                    ).trim()
                    env.GIT_AUTHOR = sh(
                        script: 'git log -1 --pretty=%an',
                        returnStdout: true
                    ).trim()
                }
                echo "✅ Branch: ${GIT_BRANCH}"
                echo "✅ Author: ${GIT_AUTHOR}"
                echo "✅ Commit: ${GIT_COMMIT_MSG}"
            }
        }

        stage('Maven Build') {
            steps {
                dir('app') {
                    sh 'mvn clean package -DskipTests -q'
                    echo "✅ Build successful!"
                }
            }
            post {
                success {
                    archiveArtifacts \
                        artifacts: 'app/target/*.jar',
                        fingerprint: true
                }
            }
        }

        stage('Unit Tests') {
            steps {
                dir('app') {
                    sh 'mvn test'
                    echo "✅ Tests passed!"
                }
            }
            post {
                always {
                    junit 'app/target/surefire-reports/*.xml'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('app') {
                    withSonarQubeEnv('SonarQube-Server') {
                        sh """
                            mvn sonar:sonar \
                            -Dsonar.projectKey=bankpay-service \
                            -Dsonar.projectName="BankPay Service" \
                            -Dsonar.host.url=${SONAR_URL}
                        """
                    }
                }
                echo "✅ SonarQube analysis done!"
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
                echo "✅ Quality Gate PASSED!"
            }
        }

        stage('Build & Push Image (Kaniko)') {
steps {
withCredentials([usernamePassword(
credentialsId: 'dockerhub-creds',
usernameVariable: 'DOCKER_USER',
passwordVariable: 'DOCKER_PASS'
)]) {


        sh '''
        echo "Creating Docker auth..."

        echo "Starting Kaniko build..."

        kubectl run kaniko-${BUILD_NUMBER} \
          --image=gcr.io/kaniko-project/executor:latest \
          --restart=Never \
          --namespace=jenkins \
          --overrides='{
            "apiVersion": "v1",
            "spec": {
              "containers": [{
                "name": "kaniko",
                "image": "gcr.io/kaniko-project/executor:latest",
                "args": [
                  "--dockerfile=app/Dockerfile",
                  "--context=git://github.com/Ritesh1914/bankpay-devops.git#refs/heads/main",
                  "--destination='"$DOCKER_USER"'/bankpay-service:'"${BUILD_NUMBER}"'",
                  "--destination='"$DOCKER_USER"'/bankpay-service:latest"
                ],
                "volumeMounts": [{
                  "name": "docker-config",
                  "mountPath": "/kaniko/.docker/config.json",
                  "subPath": ".dockerconfigjson"
              }]
              }],
              "volumes": [{
                "name": "docker-config",
                "secret": {
                  "secretName": "dockerhub-secret"
                }
              }]
            }
          }'

        echo "Waiting for Kaniko to finish..."

        kubectl wait --for=condition=Succeeded pod/kaniko-${BUILD_NUMBER} -n jenkins --timeout=120s || true

        kubectl logs -f kaniko-${BUILD_NUMBER} -n jenkins

        STATUS=$(kubectl get pod kaniko-${BUILD_NUMBER} -n jenkins -o jsonpath='{.status.phase}')

        echo "Kaniko status: $STATUS"

        if [ "$STATUS" != "Succeeded" ]; then
          echo "Kaniko build failed"
          exit 1
        fi

        kubectl delete pod kaniko-${BUILD_NUMBER} -n jenkins
        '''
    }
}


}


        stage('Deploy to DEV') {
            steps {
                sh """
                    helm upgrade --install bankpay-dev \
                    ${HELM_CHART} \
                    --namespace bankpay-dev \
                    --values ${HELM_CHART}/values-dev.yaml \
                    --set image.repository=${IMAGE_NAME} \
                    --set image.tag=${IMAGE_TAG} \
                    --set image.pullPolicy=Always \
                    --wait --timeout 5m
                """
                echo "✅ Deployed to bankpay-dev namespace!"
            }
        }

        stage('Smoke Test') {
            steps {
                sh """
                    sleep 15
                    kubectl run smoke-test-${BUILD_NUMBER} \
                    --image=curlimages/curl \
                    --restart=Never \
                    --rm -i \
                    --namespace=bankpay-dev \
                    -- curl -f \
                    http://bankpay-dev-service:8080/api/payments/health
                """
                echo "✅ Smoke test passed!"
            }
        }

        stage('Update Helm Chart (GitOps)') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'github-creds',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_PASS'
                )]) {
                    sh """
                        git config user.email "jenkins@bankpay.com"
                        git config user.name "Jenkins CI"

                        sed -i 's|repository:.*|repository: ${IMAGE_NAME}|' \
                        ${HELM_CHART}/values.yaml

                        sed -i 's|tag:.*|tag: "${IMAGE_TAG}"|' \
                        ${HELM_CHART}/values.yaml

                        git add ${HELM_CHART}/values.yaml
                        git commit -m \
                        "ci: update image to ${IMAGE_NAME}:${IMAGE_TAG} [skip ci]"

                        git push \
                        https://\${GIT_USER}:\${GIT_PASS}@github.com/Ritesh1914/bankpay-devops.git \
                        main
                    """
                }
                echo "✅ Helm chart updated - ArgoCD will sync to cluster!"
            }
        }
    }

    post {
        success {
            echo """
            🎉 PIPELINE SUCCESS!
            App: ${APP_NAME}
            Image: ${IMAGE_NAME}:${IMAGE_TAG}
            DockerHub: https://hub.docker.com/r/${DOCKERHUB_USER}/${APP_NAME}
            """
        }
        failure {
            echo "❌ PIPELINE FAILED - Check logs above"
        }
    }
}
