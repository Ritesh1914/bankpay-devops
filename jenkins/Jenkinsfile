pipeline {
    agent any

    environment {
        APP_NAME       = "bankpay-service"
        DOCKERHUB_USER = "riteshsingh90"
        IMAGE_NAME     = "${DOCKERHUB_USER}/${APP_NAME}"
        IMAGE_TAG      = "${BUILD_NUMBER}"
        SONAR_URL      = "http://sonarqube-sonarqube.sonarqube.svc.cluster.local:9000"
        HELM_CHART     = "helm/bankpay"
        K8S_NAMESPACE  = "jenkins"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 45, unit: 'MINUTES')
        timestamps()
    }

    stages {

        stage('🔍 Checkout') {
            steps {
                checkout scm
                script {
                    env.GIT_AUTHOR = sh(
                        script: 'git log -1 --pretty=%an',
                        returnStdout: true
                    ).trim()
                    env.GIT_COMMIT_MSG = sh(
                        script: 'git log -1 --pretty=%B',
                        returnStdout: true
                    ).trim()
                }
                echo "📦 Branch: ${GIT_BRANCH}"
                echo "👤 Author: ${GIT_AUTHOR}"
                echo "💬 Commit: ${GIT_COMMIT_MSG}"
            }
        }

        stage('🔨 Maven Build') {
            steps {
                dir('app') {
                    sh 'mvn clean package -DskipTests -q'
                    echo "✅ Build successful!"
                    // Verify JAR exists
                    sh 'ls -la target/*.jar'
                }
            }
            post {
                success {
                    archiveArtifacts \
                        artifacts: 'app/target/*.jar',
                        fingerprint: true
                }
            }
        }

        stage('🧪 Unit Tests') {
            steps {
                dir('app') {
                    sh 'mvn test'
                }
            }
            post {
                always {
                    junit 'app/target/surefire-reports/*.xml'
                    jacoco(
                        execPattern: 'app/target/jacoco.exec',
                        classPattern: 'app/target/classes',
                        sourcePattern: 'app/src/main/java',
                        minimumInstructionCoverage: '70'
                    )
                }
            }
        }

        stage('🔐 SonarQube Analysis') {
            steps {
                dir('app') {
                    withSonarQubeEnv('SonarQube-Server') {
                        sh """
                            mvn sonar:sonar \
                            -Dsonar.projectKey=bankpay-service \
                            -Dsonar.projectName="BankPay Service" \
                            -Dsonar.host.url=${SONAR_URL}
                        """
                    }
                }
                echo "✅ SonarQube analysis done!"
            }
        }

        stage('🚦 Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
                echo "✅ Quality Gate PASSED!"
            }
        }

        stage('🐳 Build & Push (Kaniko)') {
            steps {
                script {
                    // Cleanup previous pod
                    sh """
                        kubectl delete pod kaniko-build-${BUILD_NUMBER} \
                        -n ${K8S_NAMESPACE} \
                        --ignore-not-found=true 2>/dev/null || true
                        sleep 2
                    """

                    // Create a ConfigMap with single-stage Dockerfile
                    // This avoids multi-stage build issue with KIND
                    sh """
                        kubectl create configmap \
                        kaniko-dockerfile-${BUILD_NUMBER} \
                        --from-literal=Dockerfile='FROM eclipse-temurin:17-jre-alpine
WORKDIR /app
RUN addgroup -S appgroup && adduser -S appuser -G appgroup
COPY app.jar app.jar
USER appuser
EXPOSE 8080
HEALTHCHECK --interval=30s --timeout=3s CMD wget -q --spider http://localhost:8080/api/payments/health || exit 1
ENTRYPOINT ["java", "-jar", "app.jar"]' \
                        -n ${K8S_NAMESPACE} \
                        --dry-run=client -o yaml | \
                        kubectl apply -f -
                    """

                    // Upload JAR to a PVC or use git context
                    // We use a trick: copy JAR via initContainer
                    writeFile file: "kaniko-${BUILD_NUMBER}.yaml",
                    text: """
apiVersion: v1
kind: Pod
metadata:
  name: kaniko-build-${BUILD_NUMBER}
  namespace: ${K8S_NAMESPACE}
spec:
  restartPolicy: Never
  initContainers:
    - name: copy-jar
      image: eclipse-temurin:17-jre-alpine
      command:
        - sh
        - -c
        - |
          cp /jar/bankpay-service-1.0.0.jar /workspace/app.jar
          echo "JAR copied successfully"
          ls -la /workspace/
      volumeMounts:
        - name: workspace
          mountPath: /workspace
        - name: jar-volume
          mountPath: /jar
  containers:
    - name: kaniko
      image: gcr.io/kaniko-project/executor:v1.9.0
      args:
        - "--dockerfile=/workspace/Dockerfile"
        - "--context=dir:///workspace"
        - "--destination=${IMAGE_NAME}:${IMAGE_TAG}"
        - "--destination=${IMAGE_NAME}:latest"
        - "--log-format=text"
        - "--verbosity=info"
      volumeMounts:
        - name: docker-config
          mountPath: /kaniko/.docker
        - name: workspace
          mountPath: /workspace
        - name: dockerfile-config
          mountPath: /workspace/Dockerfile
          subPath: Dockerfile
  volumes:
    - name: workspace
      emptyDir: {}
    - name: jar-volume
      hostPath:
        path: /var/jenkins_home/workspace/bankpay-pipeline/app/target
        type: Directory
    - name: docker-config
      projected:
        sources:
          - secret:
              name: dockerhub-secret
              items:
                - key: .dockerconfigjson
                  path: config.json
    - name: dockerfile-config
      configMap:
        name: kaniko-dockerfile-${BUILD_NUMBER}
"""

                    sh "kubectl apply -f kaniko-${BUILD_NUMBER}.yaml"
                    echo "🚀 Kaniko pod started!"
                    sh "sleep 15"

                    // Stream logs
                    echo "📋 Kaniko logs:"
                    sh """
                        kubectl logs -f kaniko-build-${BUILD_NUMBER} \
                        -n ${K8S_NAMESPACE} || true
                    """

                    // Poll status
                    def finalStatus = ""
                    for (int i = 0; i < 30; i++) {
                        finalStatus = sh(
                            script: """
                                kubectl get pod \
                                kaniko-build-${BUILD_NUMBER} \
                                -n ${K8S_NAMESPACE} \
                                -o jsonpath='{.status.phase}' \
                                2>/dev/null || echo 'Unknown'
                            """,
                            returnStdout: true
                        ).trim()

                        echo "Status [${i}]: ${finalStatus}"

                        if (finalStatus == 'Succeeded' ||
                            finalStatus == 'Failed') {
                            break
                        }
                        sleep(10)
                    }

                    // Show logs on failure
                    if (finalStatus != 'Succeeded') {
                        sh """
                            kubectl describe pod \
                            kaniko-build-${BUILD_NUMBER} \
                            -n ${K8S_NAMESPACE} || true
                            kubectl logs \
                            kaniko-build-${BUILD_NUMBER} \
                            -n ${K8S_NAMESPACE} || true
                        """
                    }

                    // Cleanup
                    sh """
                        kubectl delete pod \
                        kaniko-build-${BUILD_NUMBER} \
                        -n ${K8S_NAMESPACE} \
                        --ignore-not-found=true || true

                        kubectl delete configmap \
                        kaniko-dockerfile-${BUILD_NUMBER} \
                        -n ${K8S_NAMESPACE} \
                        --ignore-not-found=true || true

                        rm -f kaniko-${BUILD_NUMBER}.yaml
                    """

                    if (finalStatus != 'Succeeded') {
                        error "❌ Kaniko build failed! Status: ${finalStatus}"
                    }

                    echo "✅ Image pushed: ${IMAGE_NAME}:${IMAGE_TAG}"
                }
            }
        }

        stage('🚀 Deploy to DEV') {
            steps {
                sh """
                    helm upgrade --install bankpay-dev \
                    ${HELM_CHART} \
                    --namespace bankpay-dev \
                    --values ${HELM_CHART}/values-dev.yaml \
                    --set image.repository=${IMAGE_NAME} \
                    --set image.tag=${IMAGE_TAG} \
                    --set image.pullPolicy=Always \
                    --wait --timeout 5m
                """
                echo "✅ Deployed to DEV!"
            }
        }

        stage('🔍 Smoke Test') {
            steps {
                sh """
                    sleep 15
                    kubectl run smoke-test-${BUILD_NUMBER} \
                    --image=curlimages/curl \
                    --restart=Never --rm -i \
                    --namespace=bankpay-dev \
                    -- curl -f \
                    http://bankpay-dev-service:8080/api/payments/health
                """
                echo "✅ Smoke test passed!"
            }
        }

        stage('🔄 Update Helm Chart (GitOps)') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'github-creds',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_PASS'
                )]) {
                    sh """
                        git config user.email "jenkins@bankpay.com"
                        git config user.name "Jenkins CI"

                        sed -i \
                        's|repository:.*|repository: ${IMAGE_NAME}|' \
                        ${HELM_CHART}/values.yaml

                        sed -i \
                        's|tag:.*|tag: "${IMAGE_TAG}"|' \
                        ${HELM_CHART}/values.yaml

                        git add ${HELM_CHART}/values.yaml
                        git diff --cached --quiet || \
                        git commit -m \
                        "ci: update image to ${IMAGE_TAG} [skip ci]"

                        git push \
                        https://\${GIT_USER}:\${GIT_PASS}@github.com/Ritesh1914/bankpay-devops.git \
                        HEAD:main
                    """
                }
                echo "✅ Helm updated - ArgoCD syncing!"
            }
        }
    }

    post {
        success {
            echo """
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
🎉 PIPELINE SUCCESS!
App:     ${APP_NAME}
Image:   ${IMAGE_NAME}:${IMAGE_TAG}
Branch:  ${GIT_BRANCH}
Author:  ${GIT_AUTHOR}
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
            """
        }
        failure {
            sh """
                kubectl delete pod kaniko-build-${BUILD_NUMBER} \
                -n ${K8S_NAMESPACE} \
                --ignore-not-found=true || true

                kubectl delete configmap \
                kaniko-dockerfile-${BUILD_NUMBER} \
                -n ${K8S_NAMESPACE} \
                --ignore-not-found=true || true

                rm -f kaniko-${BUILD_NUMBER}.yaml || true
            """
            echo "❌ PIPELINE FAILED"
        }
    }
}
EOF

echo "✅ Updated Jenkinsfile!"