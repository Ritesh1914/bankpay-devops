cat > ~/bankpay-devops/jenkins/Jenkinsfile << 'EOF'
pipeline {
    agent any

    environment {
        APP_NAME       = "bankpay-service"
        DOCKERHUB_USER = "riteshsingh90"
        IMAGE_NAME     = "${DOCKERHUB_USER}/${APP_NAME}"
        IMAGE_TAG      = "${BUILD_NUMBER}"
        SONAR_URL      = "http://sonarqube-sonarqube.sonarqube.svc.cluster.local:9000"
        HELM_CHART     = "helm/bankpay"
        K8S_NAMESPACE  = "jenkins"
        WORKSPACE_PVC  = "kaniko-workspace"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 45, unit: 'MINUTES')
        timestamps()
    }

    stages {

        stage('🔍 Checkout') {
            steps {
                checkout scm
                script {
                    env.GIT_AUTHOR = sh(
                        script: 'git log -1 --pretty=%an',
                        returnStdout: true
                    ).trim()
                    env.GIT_COMMIT_MSG = sh(
                        script: 'git log -1 --pretty=%B',
                        returnStdout: true
                    ).trim()
                }
                echo "📦 Branch: ${GIT_BRANCH}"
                echo "👤 Author: ${GIT_AUTHOR}"
                echo "💬 Commit: ${GIT_COMMIT_MSG}"
            }
        }

        stage('🔨 Maven Build') {
            steps {
                dir('app') {
                    sh 'mvn clean package -DskipTests -q'
                    sh 'ls -lh target/*.jar'
                    echo "✅ Build successful!"
                }
            }
            post {
                success {
                    archiveArtifacts \
                        artifacts: 'app/target/*.jar',
                        fingerprint: true
                }
            }
        }

        stage('🧪 Unit Tests') {
            steps {
                dir('app') {
                    sh 'mvn test'
                }
            }
            post {
                always {
                    junit 'app/target/surefire-reports/*.xml'
                    jacoco(
                        execPattern: 'app/target/jacoco.exec',
                        classPattern: 'app/target/classes',
                        sourcePattern: 'app/src/main/java',
                        minimumInstructionCoverage: '70'
                    )
                }
            }
        }

        stage('🔐 SonarQube Analysis') {
            steps {
                dir('app') {
                    withSonarQubeEnv('SonarQube-Server') {
                        sh """
                            mvn sonar:sonar \
                            -Dsonar.projectKey=bankpay-service \
                            -Dsonar.projectName="BankPay Service" \
                            -Dsonar.host.url=${SONAR_URL}
                        """
                    }
                }
                echo "✅ SonarQube done!"
            }
        }

        stage('🚦 Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
                echo "✅ Quality Gate PASSED!"
            }
        }

        stage('📦 Prepare Kaniko Context') {
            steps {
                sh """
                    # Copy JAR and Dockerfile to PVC
                    # via a helper pod that mounts the PVC

                    # Create helper pod to copy files
                    kubectl run kaniko-prep-${BUILD_NUMBER} \
                    --image=busybox:latest \
                    --restart=Never \
                    --namespace=${K8S_NAMESPACE} \
                    --overrides='{
                      "spec": {
                        "containers": [{
                          "name": "kaniko-prep-${BUILD_NUMBER}",
                          "image": "busybox:latest",
                          "command": ["sh", "-c", "sleep 300"],
                          "volumeMounts": [{
                            "name": "workspace",
                            "mountPath": "/workspace"
                          }]
                        }],
                        "volumes": [{
                          "name": "workspace",
                          "persistentVolumeClaim": {
                            "claimName": "${WORKSPACE_PVC}"
                          }
                        }]
                      }
                    }'

                    # Wait for helper pod to start
                    sleep 10
                    kubectl wait pod/kaniko-prep-${BUILD_NUMBER} \
                    --for=condition=Ready \
                    --timeout=60s \
                    -n ${K8S_NAMESPACE}
                """

                // Copy JAR to PVC via helper pod
                sh """
                    # Copy JAR into the PVC
                    kubectl cp \
                    app/target/bankpay-service-1.0.0.jar \
                    ${K8S_NAMESPACE}/kaniko-prep-${BUILD_NUMBER}:/workspace/app.jar

                    echo "✅ JAR copied to PVC"
                """

                // Create Dockerfile on PVC
                sh """
                    kubectl exec \
                    kaniko-prep-${BUILD_NUMBER} \
                    -n ${K8S_NAMESPACE} \
                    -- sh -c 'cat > /workspace/Dockerfile << DOCKERFILE
FROM eclipse-temurin:17-jre-alpine
WORKDIR /app
RUN addgroup -S appgroup && adduser -S appuser -G appgroup
COPY app.jar app.jar
USER appuser
EXPOSE 8080
ENTRYPOINT ["java", "-jar", "app.jar"]
DOCKERFILE'

                    echo "✅ Dockerfile created on PVC"

                    # Verify files
                    kubectl exec \
                    kaniko-prep-${BUILD_NUMBER} \
                    -n ${K8S_NAMESPACE} \
                    -- ls -lh /workspace/
                """

                // Cleanup helper pod
                sh """
                    kubectl delete pod \
                    kaniko-prep-${BUILD_NUMBER} \
                    -n ${K8S_NAMESPACE} \
                    --ignore-not-found=true
                """

                echo "✅ Kaniko context ready on PVC!"
            }
        }

        stage('🐳 Build & Push (Kaniko)') {
            steps {
                script {
                    // Cleanup previous kaniko pod
                    sh """
                        kubectl delete pod \
                        kaniko-build-${BUILD_NUMBER} \
                        -n ${K8S_NAMESPACE} \
                        --ignore-not-found=true || true
                        sleep 2
                    """

                    // Create Kaniko pod using PVC context
                    writeFile file: "kaniko-${BUILD_NUMBER}.yaml",
                    text: """
apiVersion: v1
kind: Pod
metadata:
  name: kaniko-build-${BUILD_NUMBER}
  namespace: ${K8S_NAMESPACE}
spec:
  restartPolicy: Never
  containers:
    - name: kaniko
      image: gcr.io/kaniko-project/executor:v1.9.0
      args:
        - "--dockerfile=/workspace/Dockerfile"
        - "--context=dir:///workspace"
        - "--destination=${IMAGE_NAME}:${IMAGE_TAG}"
        - "--destination=${IMAGE_NAME}:latest"
        - "--log-format=text"
        - "--verbosity=info"
      volumeMounts:
        - name: workspace
          mountPath: /workspace
        - name: docker-config
          mountPath: /kaniko/.docker
  volumes:
    - name: workspace
      persistentVolumeClaim:
        claimName: ${WORKSPACE_PVC}
    - name: docker-config
      projected:
        sources:
          - secret:
              name: dockerhub-secret
              items:
                - key: .dockerconfigjson
                  path: config.json
"""

                    sh "kubectl apply -f kaniko-${BUILD_NUMBER}.yaml"
                    echo "🚀 Kaniko pod started!"
                    sh "sleep 10"

                    // Stream logs
                    echo "📋 Kaniko logs:"
                    sh """
                        kubectl logs -f \
                        kaniko-build-${BUILD_NUMBER} \
                        -n ${K8S_NAMESPACE} || true
                    """

                    // Poll status
                    def finalStatus = ""
                    for (int i = 0; i < 30; i++) {
                        finalStatus = sh(
                            script: """
                                kubectl get pod \
                                kaniko-build-${BUILD_NUMBER} \
                                -n ${K8S_NAMESPACE} \
                                -o jsonpath='{.status.phase}' \
                                2>/dev/null || echo 'Unknown'
                            """,
                            returnStdout: true
                        ).trim()

                        echo "Kaniko status [${i}]: ${finalStatus}"

                        if (finalStatus == 'Succeeded' ||
                            finalStatus == 'Failed') {
                            break
                        }
                        sleep(10)
                    }

                    if (finalStatus != 'Succeeded') {
                        sh """
                            kubectl describe pod \
                            kaniko-build-${BUILD_NUMBER} \
                            -n ${K8S_NAMESPACE} || true
                        """
                    }

                    // Cleanup
                    sh """
                        kubectl delete pod \
                        kaniko-build-${BUILD_NUMBER} \
                        -n ${K8S_NAMESPACE} \
                        --ignore-not-found=true || true
                        rm -f kaniko-${BUILD_NUMBER}.yaml
                    """

                    if (finalStatus != 'Succeeded') {
                        error "❌ Kaniko failed! Status: ${finalStatus}"
                    }

                    echo "✅ Image pushed: ${IMAGE_NAME}:${IMAGE_TAG}"
                }
            }
        }

        stage('🚀 Deploy to DEV') {
            steps {
                sh """
                    helm upgrade --install bankpay-dev \
                    ${HELM_CHART} \
                    --namespace bankpay-dev \
                    --values ${HELM_CHART}/values-dev.yaml \
                    --set image.repository=${IMAGE_NAME} \
                    --set image.tag=${IMAGE_TAG} \
                    --set image.pullPolicy=Always \
                    --wait --timeout 5m
                """
                echo "✅ Deployed to DEV!"
            }
        }

        stage('🔍 Smoke Test') {
            steps {
                sh """
                    sleep 15
                    kubectl run smoke-test-${BUILD_NUMBER} \
                    --image=curlimages/curl \
                    --restart=Never --rm -i \
                    --namespace=bankpay-dev \
                    -- curl -f \
                    http://bankpay-dev-service:8080/api/payments/health
                """
                echo "✅ Smoke test passed!"
            }
        }

        stage('🔄 Update Helm Chart (GitOps)') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'github-creds',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_PASS'
                )]) {
                    sh """
                        git config user.email "jenkins@bankpay.com"
                        git config user.name "Jenkins CI"

                        sed -i \
                        's|repository:.*|repository: ${IMAGE_NAME}|' \
                        ${HELM_CHART}/values.yaml

                        sed -i \
                        's|tag:.*|tag: "${IMAGE_TAG}"|' \
                        ${HELM_CHART}/values.yaml

                        git add ${HELM_CHART}/values.yaml
                        git diff --cached --quiet || \
                        git commit -m \
                        "ci: update image to ${IMAGE_TAG} [skip ci]"

                        git push \
                        https://\${GIT_USER}:\${GIT_PASS}@github.com/Ritesh1914/bankpay-devops.git \
                        HEAD:main
                    """
                }
                echo "✅ Helm updated - ArgoCD syncing!"
            }
        }
    }

    post {
        success {
            echo """
━━━━━━━━━━━━━━━━━━━━━━━━
🎉 PIPELINE SUCCESS!
App:   ${APP_NAME}
Image: ${IMAGE_NAME}:${IMAGE_TAG}
━━━━━━━━━━━━━━━━━━━━━━━━
            """
        }
        failure {
            sh """
                kubectl delete pod \
                kaniko-build-${BUILD_NUMBER} \
                kaniko-prep-${BUILD_NUMBER} \
                -n ${K8S_NAMESPACE} \
                --ignore-not-found=true || true
                rm -f kaniko-${BUILD_NUMBER}.yaml || true
            """
            echo "❌ PIPELINE FAILED"
        }
    }
}
EOF

echo "✅ Jenkinsfile updated!"